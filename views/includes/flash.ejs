<!-- ek flash success ke liye hai aur ek error ke liye hai -->
<% if(success && success.length){ %>
<div class="alert alert-success alert-dismissible fade show col-6 offset-4" role="alert">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<% if(error && error.length){ %>
<div class="alert alert-denger alert-dismissible fade show col-6 offset-4" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>